# goodvision (Anthropic-compatible gateway) — key is inlined into the JS
# bundle at build time. Fine for personal builds; move behind a server
# before any public release. Never commit .env.
EXPO_PUBLIC_GOODVISION_API_KEY=sk-...

# Optional overrides
# EXPO_PUBLIC_GOODVISION_BASE_URL=https://api.goodvision.tech
# EXPO_PUBLIC_GOODVISION_MODEL=claude-sonnet-4-6
