# goodvision (Anthropic-compatible gateway) — key is inlined into the JS
# bundle at build time. Fine for personal builds; move behind a server
# before any public release. Never commit .env.
EXPO_PUBLIC_GOODVISION_API_KEY=sk-...

# Optional overrides
# EXPO_PUBLIC_GOODVISION_BASE_URL=https://api.goodvision.tech
# EXPO_PUBLIC_GOODVISION_MODEL=claude-sonnet-4-6

# Google Sign-In OAuth client IDs (see README → 第三方登录).
# Leave BOTH unset to hide the Google button; the app falls back to
# email + Sign in with Apple. Apple needs no env — it uses the bundle id.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
