{
  "expo": {
    "name": "KnowTok",
    "slug": "knowtok",
    "scheme": "knowtok",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B1020"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1020"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
