DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require
REDIS_URL=redis://localhost:6379/0
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_EMBEDDING_TIMEOUT_SECONDS=60
ZHIPU_CHAT_TIMEOUT_SECONDS=120
ZHIPU_REQUEST_RETRIES=3
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_TIMEOUT_SECONDS=30
SEMANTIC_SCHOLAR_RPS=1
SEMANTIC_SCHOLAR_BACKFILL_BATCH_SIZE=10
ARXIV_CATEGORY_SET=cs.AI,cs.LG,q-bio
ARXIV_LOOKBACK_DAYS=7
EMBEDDING_MODEL=embedding-3
CHAT_MODEL=glm-4.5-air
HOOK_TEMPLATE_ID=default_v1
DEFAULT_USER_PROFILE_HASH=generic_zh_cn
WORKER_TIMEZONE=America/Los_Angeles
TASK_ALWAYS_EAGER=false
